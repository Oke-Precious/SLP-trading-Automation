NODE_ENV=your_node_env_here
PORT=your_port_here
HOST=your_host_here

# Database (update with your credentials)
DATABASE_URL=your_database_url_here

# Redis
REDIS_URL=your_redis_url_here

# JWT Secrets (change these in production — use: openssl rand -base64 64)
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_EXPIRES_IN=your_jwt_expiration_duration_here
JWT_REFRESH_EXPIRES_IN=your_jwt_refresh_expiration_duration_here

# Market Data APIs
TWELVE_DATA_KEY=your_twelve_data_api_key_here
BINANCE_REST_URL=your_binance_rest_endpoint_here
BINANCE_WS_URL=your_binance_ws_endpoint_here

# Email (use Mailtrap for dev: https://mailtrap.io)
SMTP_HOST=your_smtp_host_here
SMTP_PORT=your_smtp_port_here
SMTP_USER=your_smtp_user_here
SMTP_PASS=your_smtp_pass_here
EMAIL_FROM=your_email_sender_address_here

# Client URL (for CORS)
CLIENT_URL=your_client_url_here

# Admin
ADMIN_EMAIL=your_admin_email_here
