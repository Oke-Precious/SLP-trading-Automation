rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net: default deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for users and their subcollections (POIs, Trades, Alerts, Settings)
    // - Enforces robust, strict data isolation per-user
    // - Users can ONLY read and write their own documents across all subpaths
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      match /{subPath=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
