rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Firebase startup healthcheck
    match /test/connection {
      allow read: if true;
    }

    // Explicit match for user's own document
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Public usernames registry for signup uniqueness and suggestions
    match /usernames/{username} {
      allow read, create: if true;
    }

    // Explicit match for user's settings or subcollection documents (like users/{userId}/settings/bias)
    match /users/{userId}/{subcollection}/{documentId} {
      allow read, write: if isOwner(userId);
    }

    // Rules for all nested paths as a catch-all
    match /users/{userId}/{allPaths=**} {
      allow read, write: if isOwner(userId);
    }
  }
}
